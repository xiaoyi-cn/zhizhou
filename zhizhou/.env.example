# 知舟 环境变量配置

# 数据库
DATABASE_URL=postgres://zhizhou:your_password@localhost:5432/zhizhou?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-random-string

# 加密密钥（AES-256，必须 32 字节）
ENCRYPTION_KEY=change-me-32-bytes-key-123456!

# 部署模式: cloud=官方云端, local=本地部署(解锁全部功能)
DEPLOY_MODE=local

# Embedding 向量维度
# DeepSeek/OpenAI: 1536 | 混元: 1024 | 豆包: 4096
EMBEDDING_DIM=1536

# 短信验证码（阿里云短信/腾讯云短信）
SMS_API_KEY=
SMS_API_SECRET=

# 服务端口
SERVER_PORT=8080